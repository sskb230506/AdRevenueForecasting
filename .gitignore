# pyenv
#   For a library or app, you might want to share your .python-version.
#   For an executable, you probably don't.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, Python paths might vary.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the resolved dependencies, and is recommended to be checked-in.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the resolved dependencies, and is recommended to be checked-in.
#.pdm-python.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

